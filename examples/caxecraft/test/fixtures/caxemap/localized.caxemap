CAXEMAP 1
feature required caxecraft:core
map tutorial.localized
asset-pack packs/caxecraft/base
default-locale en
locale en
  message dialogue.ivvy.hello "Ready to build?"
  message objective.meet-ivvy.body "Walk to Ivvy near the meadow."
  message objective.meet-ivvy.title "Meet Ivvy"
  message scenario.tutorial.title "First map tutorial"
end locale
locale es-mx
  message dialogue.ivvy.hello "¿Lista para construir?"
  message objective.meet-ivvy.body "Camina hacia Ivvy cerca del prado."
  message objective.meet-ivvy.title "Conoce a Ivvy"
  message scenario.tutorial.title "Tutorial del primer mapa"
end locale
title message scenario.tutorial.title
mode creative
world 4 4 4
palette 0 caxecraft:air
palette 1 caxecraft:bedrock
chunk world.base 0 0 0 4 4 4
  run 1 4
  run 0 12
  run 1 4
  run 0 12
  run 1 4
  run 0 12
  run 1 4
  run 0 12
end chunk
object guide.ivvy
  tag friend
  placement npc caxecraft:ivvy dialogue.ivvy.hello 2500 1000 1500 270
end object
object player.start
  tag player
  placement player-spawn 1500 1000 1500 0
end object
dialogue dialogue.ivvy.hello
  line speaker guide.ivvy message dialogue.ivvy.hello
end dialogue
objective objective.meet-ivvy active title message objective.meet-ivvy.title
  body message objective.meet-ivvy.body
end objective
end-map
