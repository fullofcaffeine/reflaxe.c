# reflaxe.c source-checkout library configuration.
#
# Do not replace ${SCOPE_DIR} with caller-relative paths. The target override
# root will be added after `std/c/_std` is restored and provenance-registered.

-cp ${SCOPE_DIR}/src/
-cp ${SCOPE_DIR}/std/
-lib reflaxe

-D reflaxe.c=0.0.0-development
--macro nullSafety("reflaxe.c")
--macro reflaxe.c.CompilerBootstrap.Start()
--macro reflaxe.c.CompilerInit.Start()
