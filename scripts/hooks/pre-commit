#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

if [ "${BD_GIT_HOOK:-}" = "1" ]; then
  exit 0
fi

if [ -d "$ROOT_DIR/.beads" ] && command -v bd >/dev/null 2>&1; then
  if bd -C "$ROOT_DIR" context >/dev/null 2>&1; then
    echo "[pre-commit] Exporting Beads issues to JSONL..."
    BEADS_EXPORT_TMP="$(mktemp)"
    BEADS_EXPORT_NORMALIZED="$(mktemp)"
    trap 'rm -f "$BEADS_EXPORT_TMP" "$BEADS_EXPORT_NORMALIZED"' EXIT
    bd -C "$ROOT_DIR" export > "$BEADS_EXPORT_TMP"
    # Newer bd builds may append a blank record. JSONL permits no such record,
    # and the repository whitespace guard intentionally rejects it.
    awk 'NF { print }' "$BEADS_EXPORT_TMP" > "$BEADS_EXPORT_NORMALIZED"
    mv -f "$BEADS_EXPORT_NORMALIZED" "$ROOT_DIR/.beads/issues.jsonl"
    rm -f "$BEADS_EXPORT_TMP"
    git -C "$ROOT_DIR" add .beads/issues.jsonl
    trap - EXIT
  else
    echo "[pre-commit] WARN: Beads database is not bootstrapped; skipping export."
  fi
fi

STAGED_HX_FILES=()
while IFS= read -r staged_file; do
  case "$staged_file" in
    vendor/*|third_party/*|runtime/vendor/*|runtime/third_party/*)
      # Third-party bytes are immutable inputs. Formatting would silently fork
      # the reviewed upstream bundle and invalidate its provenance checksum.
      continue
      ;;
  esac
  if [ -n "$staged_file" ] && [ -f "$ROOT_DIR/$staged_file" ]; then
    STAGED_HX_FILES+=("$staged_file")
  fi
done < <(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.hx$' || true)

if [ "${#STAGED_HX_FILES[@]}" -gt 0 ]; then
  bash "$ROOT_DIR/scripts/lint/hx_format_guard.sh" --tool-only

  echo "[pre-commit] Formatting staged Haxe files..."
  FORMAT_ARGS=()
  for hx_file in "${STAGED_HX_FILES[@]}"; do
    FORMAT_ARGS+=("-s" "$ROOT_DIR/$hx_file")
  done
  haxelib run formatter "${FORMAT_ARGS[@]}"
  git add -- "${STAGED_HX_FILES[@]}"
fi

echo "[pre-commit] Running local path guard..."
bash "$ROOT_DIR/scripts/lint/local_path_guard_staged.sh"

echo "[pre-commit] Checking staged whitespace..."
bash "$ROOT_DIR/scripts/lint/whitespace_guard.sh" --staged

echo "[pre-commit] Running staged secret scan..."
bash "$ROOT_DIR/scripts/security/run-gitleaks.sh" --staged

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR || true)"

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(\.beads/hooks/(pre-commit|pre-push)|\.github/workflows/|\.gitignore|\.gitleaks\.toml|AGENTS\.md|CONTRIBUTING\.md|README\.md|package\.json|scripts/(beads/push-safe\.sh|ci/(check_ci_policy|check_security_tooling|install-gitleaks)\.py|ci/install-gitleaks\.sh|hooks/|lint/hx_format_guard\.sh|security/run-(beads-)?gitleaks\.sh))'; then
  echo "[pre-commit] Validating security-tool pins, hooks, and public-repository leak guards..."
  python3 "$ROOT_DIR/scripts/ci/check_security_tooling.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^docs/specs/.*\.json$'; then
  if ! command -v jq >/dev/null 2>&1; then
    echo "[pre-commit] ERROR: jq is required to validate staged JSON specs." >&2
    exit 1
  fi
  echo "[pre-commit] Validating JSON specs..."
  while IFS= read -r json_file; do
    if [ -n "$json_file" ] && [ -f "$json_file" ]; then
      jq empty "$json_file"
    fi
  done < <(printf '%s\n' "$STAGED_FILES" | grep -E '^docs/specs/.*\.json$' || true)
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(AGENTS\.md|README\.md|CONTRIBUTING\.md|SECURITY\.md|docs/|package\.json|\.github/workflows/governance\.yml|scripts/(beads/|ci/|test/)|src/|std/c/|runtime/hxrt/|test/)'; then
  echo "[pre-commit] Validating bootstrap capability and limitation claims..."
  python3 "$ROOT_DIR/scripts/ci/check_capability_manifest.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '(^|/)[^/]+\.hx$|^(AGENTS\.md|CONTRIBUTING\.md|README\.md|docs/(PRD|architecture|typed-boundaries)\.md|docs/specs/typed-boundaries(\.schema)?\.json|package\.json|\.github/workflows/governance\.yml|scripts/ci/(check_ci_policy|check_typed_boundaries)\.py|test/governance/test_typed_boundaries\.py)$'; then
  echo "[pre-commit] Rejecting unreviewed untyped Haxe boundaries..."
  python3 "$ROOT_DIR/scripts/ci/check_typed_boundaries.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(AGENTS\.md|CONTRIBUTING\.md|SECURITY\.md|README\.md|docs/PRD\.md|package\.json|\.github/workflows/governance\.yml|scripts/ci/(check_ci_policy|check_governance_policy)\.py|test/governance/test_governance_policy\.py)'; then
  echo "[pre-commit] Validating contribution, disclosure, and release governance..."
  npm run test:governance-policy
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(AGENTS\.md|README\.md|docs/(BEADS_PLAN|PRD)\.md|docs/specs/beads-plan(\.schema)?\.json|scripts/beads/|test/governance/test_beads_bootstrap\.py|package\.json|\.github/workflows/governance\.yml|scripts/ci/check_ci_policy\.py|\.gitignore$)'; then
  echo "[pre-commit] Validating and previewing the reproducible Beads graph..."
  npm run test:beads-plan
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(AGENTS\.md|README\.md|examples/|docs/(PRD|aggregate-lowering|architecture|array-runtime|arithmetic-semantics|body-lowering|class-layout|diagnostics|enum-lowering|evaluation-order|function-lowering|generic-specialization|primitive-differential|primitive-semantics|project-emission|raylib-provisioning|runtime-feature-planning|string-runtime|span-lowering|static-initialization|stdlib-ledger|symbol-naming|testing|typed-ast-input|typed-c-authoring|virtual-dispatch)\.md|docs/specs/(dispatch-report\.schema|fixture-(case|taxonomy).*|primitive-divergences.*|primitive-semantics.*|raylib-provisioning.*|stdlib-ledger.*)\.(json|csv)|package\.json|scripts/(ci/check_fixture_policy|test/snapshots)\.py|test/governance/test_fixture_policy\.py|test/(positive|negative|ast|snapshot|runtime|differential|abi|performance|aggregate_lowering|c_import|raylib_provisioning|class_layout|enum_lowering|generic-specialization|virtual_dispatch|arithmetic_semantics|body_lowering|diagnostics|evaluation_order|function_lowering|primitive_differential|primitive_semantics|project_emitter|span_lowering|static_initialization|string_output|stdlib_ledger|symbol_registry|typed_ast)/)'; then
  echo "[pre-commit] Validating fixture taxonomy, snapshot ownership, and example assertions..."
  python3 "$ROOT_DIR/scripts/ci/check_fixture_policy.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(AGENTS\.md|README\.md|docs/.*\.(md|json)|src/.*\.hx$|std/c/.*\.hx$|scripts/ci/check_diagnostic_policy\.py|test/(diagnostics/|governance/test_diagnostic_policy\.py)|package\.json)'; then
	echo "[pre-commit] Validating typed diagnostic registry and JSON policy..."
	python3 "$ROOT_DIR/test/diagnostics/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(\.haxerc|haxelib\.json|package(-lock)?\.json|extraParams\.hxml|haxe_libraries/|vendor/reflaxe/|src/c/Init\.hx|src/reflaxe/c/(BuildDetection|CompilerBootstrap|CompilerInit|TargetPlatform)\.hx|docs/specs/toolchain-lock\.json|scripts/ci/check_toolchain\.py)'; then
	echo "[pre-commit] Verifying pinned toolchain and bootstrap policy..."
	python3 "$ROOT_DIR/scripts/ci/check_toolchain.py" --root "$ROOT_DIR"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(\.haxerc|haxelib\.json|package(-lock)?\.json|docs/specs/toolchain-lock\.json|scripts/ci/check_toolchain\.py|vendor/reflaxe/|haxe_libraries/|extraParams\.hxml|src/.*\.hx$|std/c/.*\.hx$|test/all_sources/|.*\.hxml$)'; then
	echo "[pre-commit] Type-checking every target-owned Haxe source..."
	python3 "$ROOT_DIR/test/all_sources/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(\.haxerc|haxelib\.json|package(-lock)?\.json|extraParams\.hxml|haxe_libraries/|vendor/reflaxe/|src/c/Init\.hx|src/reflaxe/c/(BuildDetection|BuildModeResolver|CBuildMode|CCompiler|CompilationContext|CompilerBootstrap|CompilerInit|CProfile|CReflaxeCompiler|ProfileResolver|TargetPlatform)\.hx|src/reflaxe/c/emit/|test/bootstrap/)'; then
	echo "[pre-commit] Running target identity and compiler lifecycle probes..."
	python3 "$ROOT_DIR/test/bootstrap/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(std/c/|src/reflaxe/c/(contract|macros)/|test/typed_c/|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running typed C contract probes..."
  python3 "$ROOT_DIR/test/typed_c/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(std/c/CString\.hx|src/reflaxe/c/(CCompiler\.hx|emit/|interop/|ir/|lowering/|macros/|semantics/)|test/(c_import|native/pointlib|positive/c-import|negative/c-import|snapshot/c-import|runtime/c-import|abi/c-import)/|docs/(PRD|architecture|hxc-ir|project-emission|testing|typed-c-authoring)\.md|docs/specs/(bootstrap-inventory|fixture-taxonomy)\.json|package\.json|scripts/(ci/(check_ci_policy|runtime_smoke)|test/snapshots)\.py)'; then
  echo "[pre-commit] Running generated direct C-import and ABI probes..."
  python3 "$ROOT_DIR/test/c_import/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(\.github/workflows/governance\.yml|docs/(adr/0009-raylibhx-companion-boundary|raylib-provisioning)\.md|docs/specs/(fixture-taxonomy|raylib-provisioning-lock(\.schema)?|third-party-provenance)\.json|package\.json|scripts/(ci/(check_ci_policy|check_license_policy|check_security_tooling)\.py|hooks/pre-commit|raylib/|test/snapshots\.py)|test/(raylib_provisioning|positive/raylib-provisioning|negative/raylib-provisioning|snapshot/raylib-provisioning|runtime/raylib-provisioning)/|THIRD_PARTY_NOTICES\.md)'; then
  echo "[pre-commit] Running locked Raylib provisioning, generated-C, and zero-runtime probes..."
  python3 "$ROOT_DIR/test/raylib_provisioning/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(src/reflaxe/c/(CCompiler|CReflaxeCompiler|CompilationContext)\.hx|src/reflaxe/c/frontend/|test/typed_ast/|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running typed-AST normalization and compiler-server probes..."
  python3 "$ROOT_DIR/test/typed_ast/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(src/reflaxe/c/ast/|test/c_ast/|test/ast/c-ast-roundtrip/|scripts/test/c_fixture_harness\.py|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running structural C11 AST golden probes..."
  python3 "$ROOT_DIR/test/c_ast/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(src/reflaxe/c/(ast|contract|plan)/|test/declaration_plan/|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running declaration/include planning probes..."
  python3 "$ROOT_DIR/test/declaration_plan/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(src/reflaxe/c/(CompilationContext\.hx|ast/CAST\.hx|contract/|macros/|naming/|plan/)|test/symbol_registry/|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running deterministic C symbol registry probes..."
  python3 "$ROOT_DIR/test/symbol_registry/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(src/reflaxe/c/(CCompiler|CReflaxeCompiler|CompilationContext)\.hx|src/reflaxe/c/(contract|emit|naming|plan)/|test/project_emitter/|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running deterministic multi-file project ownership probes..."
  python3 "$ROOT_DIR/test/project_emitter/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(src/reflaxe/c/(CCompiler|CompilationContext|CEnvironment|CRuntimeDiagnostics|CRuntimePolicy)\.hx|src/reflaxe/c/(emit|runtime)/|runtime/hxrt/|test/(runtime/runtime-feature-graph|string_output)/|docs/(architecture|array-runtime|configuration|project-emission|runtime-feature-planning|string-runtime|testing)\.md|docs/specs/(fixture-taxonomy|runtime-features).*\.json|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running deterministic runtime feature and selective packaging probes..."
  python3 "$ROOT_DIR/test/runtime/runtime-feature-graph/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(runtime/hxrt/(include/(hxc_runtime|hxrt/(allocator|array|base|status))\.h|src/(allocator|array)\.c|test/(runtime_smoke\.c|public_header_cpp\.cpp))|src/reflaxe/c/runtime/(RuntimeAbiContract|RuntimeFeatureCatalog)\.hx|test/differential/array-runtime/|test/runtime/runtime-feature-graph/|docs/(array-runtime|runtime-feature-planning|testing)\.md|docs/specs/(bootstrap-inventory|fixture-taxonomy)\.json|package\.json)'; then
  echo "[pre-commit] Running typed resizable-array runtime probes..."
  python3 "$ROOT_DIR/test/differential/array-runtime/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(runtime/hxrt/(include/hxrt/(abi|io|status|string|string_literal)\.h|src/(io|status|string)\.c|test/(runtime_smoke\.c|public_header_cpp\.cpp))|src/reflaxe/c/runtime/RuntimeFeatureCatalog\.hx|test/differential/string-runtime/|docs/(adr/0004-utf8-scalar-string-contract|string-runtime|runtime-feature-planning|testing)\.md|docs/specs/fixture-taxonomy\.json|package\.json)'; then
  echo "[pre-commit] Running UTF-8 scalar string runtime and CString probes..."
  python3 "$ROOT_DIR/test/differential/string-runtime/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(runtime/hxrt/(include/hxrt/(base|io|status|string_literal)\.h|src/io\.c)|src/reflaxe/c/(CCompiler\.hx|emit/CProjectEmitter\.hx|ir/|lowering/|runtime/)|test/(string_output|positive/string-output|negative/string-output|snapshot/string-output|runtime/string-output|differential/string-output)/|docs/(PRD|architecture|configuration|hxc-ir|project-emission|runtime-feature-planning|string-runtime|testing)\.md|docs/specs/(bootstrap-inventory|fixture-taxonomy|stdlib-ledger).*\.(json|csv)|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running literal UTF-8 output, selective runtime, and fail-stop I/O probes..."
  python3 "$ROOT_DIR/test/string_output/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(examples/hello/|runtime/hxrt/(include/hxrt/(base|io|status|string_literal)\.h|src/io\.c)|src/reflaxe/c/(CCompiler\.hx|emit/CProjectEmitter\.hx|ir/|lowering/|runtime/)|test/string_output/|docs/(PRD|testing)\.md|docs/specs/(bootstrap-inventory|fixture-taxonomy)\.json|package\.json|scripts/(ci/(check_ci_policy|runtime_smoke)|test/snapshots)\.py)'; then
  echo "[pre-commit] Running the generated hello product example..."
  python3 "$ROOT_DIR/examples/hello/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(\.haxerc|package(-lock)?\.json|docs/(PRD|architecture|stdlib-ledger|testing)\.md|docs/specs/(beads-plan|diagnostics|fixture-taxonomy|stdlib-ledger|toolchain-lock).*\.(json|csv)|runtime/hxrt/features\.json|scripts/(ci/check_ci_policy|test/snapshots)\.py|test/(string_output|stdlib_ledger|positive/stdlib-ledger|negative/stdlib-ledger|snapshot/stdlib-ledger)/)'; then
  echo "[pre-commit] Checking pinned standard-library ownership and parity ledger..."
  python3 "$ROOT_DIR/test/stdlib_ledger/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(src/reflaxe/c/ir/|test/hxc_ir/|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running HxcIR semantic invariant and golden probes..."
  python3 "$ROOT_DIR/test/hxc_ir/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(src/reflaxe/c/(ir|semantics)/|test/primitive_semantics/|docs/(adr/0008-primitive-representations-and-conversions|primitive-semantics)\.md|docs/specs/primitive-semantics.*\.json|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running typed primitive semantic and strict C11 probes..."
  python3 "$ROOT_DIR/test/primitive_semantics/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(src/reflaxe/c/(CCompiler\.hx|CompilationContext\.hx|ir/|lowering/|naming/|semantics/)|test/body_lowering/|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running typed Haxe body-lowering and strict native probes..."
  python3 "$ROOT_DIR/test/body_lowering/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(src/reflaxe/c/(CCompiler\.hx|CompilationContext\.hx|ast/|emit/|ir/|lowering/|naming/|plan/|semantics/)|test/function_lowering/|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running typed static-function lowering and strict native probes..."
  python3 "$ROOT_DIR/test/function_lowering/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(src/reflaxe/c/(CCompiler\.hx|CompilationContext\.hx|ast/|emit/|ir/|lowering/|macros/|naming/|plan/|semantics/)|test/(aggregate_lowering|positive/aggregate-lowering|negative/aggregate-lowering|snapshot/aggregate-lowering|runtime/aggregate-lowering|typed_c/fixtures/metal_packed_struct)/|docs/(aggregate-lowering|architecture|body-lowering|hxc-ir|project-emission|testing|typed-c-authoring)\.md|docs/specs/(bootstrap-inventory|fixture-taxonomy)\.json|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running closed aggregate lowering and C/C++ layout probes..."
  python3 "$ROOT_DIR/test/aggregate_lowering/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(\.github/workflows/governance\.yml|src/reflaxe/c/(CCompiler\.hx|CompilationContext\.hx|ast/|emit/|ir/|lowering/|naming/|plan/|runtime/|semantics/)|test/(class_layout|positive/class-layout|negative/class-layout|snapshot/class-layout|runtime/class-layout)/|docs/(PRD|architecture|body-lowering|class-layout|hxc-ir|project-emission|testing)\.md|docs/specs/(bootstrap-inventory|fixture-taxonomy)\.json|haxe_libraries/reflaxe\.c\.hxml|package\.json|scripts/(ci/(check_ci_policy|check_toolchain)\.py|hooks/pre-commit|test/snapshots\.py))'; then
  echo "[pre-commit] Running concrete class lowering and C/C++ layout probes..."
  python3 "$ROOT_DIR/test/class_layout/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(\.github/workflows/governance\.yml|src/reflaxe/c/(CCompiler\.hx|CompilationContext\.hx|ast/|emit/|ir/|lowering/|naming/|plan/|runtime/|semantics/)|test/(constructor_lowering|positive/constructor-lowering|negative/constructor-lowering|snapshot/constructor-lowering|runtime/constructor-lowering)/|docs/(PRD|architecture|body-lowering|class-layout|constructor-lowering|hxc-ir|project-emission|testing)\.md|docs/specs/(bootstrap-inventory|fixture-taxonomy)\.json|haxe_libraries/reflaxe\.c\.hxml|package\.json|scripts/(ci/(check_ci_policy|check_toolchain)\.py|hooks/pre-commit|test/snapshots\.py))'; then
  echo "[pre-commit] Running bounded constructor lowering and cleanup probes..."
  python3 "$ROOT_DIR/test/constructor_lowering/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(\.github/workflows/governance\.yml|src/reflaxe/c/(CCompiler\.hx|CompilationContext\.hx|ast/|emit/|ir/|lowering/|naming/|plan/|runtime/|semantics/)|test/(virtual_dispatch|positive/virtual-dispatch|negative/virtual-dispatch|snapshot/virtual-dispatch|runtime/virtual-dispatch)/|docs/(PRD|architecture|body-lowering|class-layout|constructor-lowering|hxc-ir|project-emission|testing|virtual-dispatch)\.md|docs/specs/(bootstrap-inventory|dispatch-report\.schema|fixture-taxonomy)\.json|haxe_libraries/reflaxe\.c\.hxml|package\.json|scripts/(ci/(check_ci_policy|check_toolchain)\.py|hooks/pre-commit|test/snapshots\.py))'; then
  echo "[pre-commit] Running closed-world virtual-dispatch and override probes..."
  python3 "$ROOT_DIR/test/virtual_dispatch/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(src/reflaxe/c/(CCompiler\.hx|CompilationContext\.hx|ast/|emit/|ir/|lowering/|naming/|plan/|runtime/|semantics/)|test/(enum_lowering|positive/enum-lowering|negative/enum-lowering|snapshot/enum-lowering|runtime/enum-lowering)/|docs/(architecture|body-lowering|enum-lowering|hxc-ir|project-emission|testing)\.md|docs/specs/(bootstrap-inventory|fixture-taxonomy)\.json|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running Haxe enum lowering and C/C++ layout probes..."
  python3 "$ROOT_DIR/test/enum_lowering/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(\.github/workflows/governance\.yml|src/reflaxe/c/(CCompiler\.hx|CompilationContext\.hx|ast/|emit/|ir/|lowering/|naming/|plan/|runtime/|semantics/)|test/(generic_specialization|positive/generic-specialization|negative/generic-specialization|snapshot/generic-specialization|runtime/generic-specialization)/|docs/(PRD|architecture|enum-lowering|function-lowering|generic-specialization|project-emission|testing)\.md|docs/specs/(bootstrap-inventory|fixture-taxonomy|generic-specialization-report\.schema)\.json|haxe_libraries/reflaxe\.c\.hxml|package\.json|scripts/(ci/(check_ci_policy|check_toolchain)\.py|hooks/pre-commit|test/snapshots\.py))'; then
  echo "[pre-commit] Running deterministic generic-specialization and code-size probes..."
  python3 "$ROOT_DIR/test/generic_specialization/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(src/reflaxe/c/(CCompiler|CReflaxeCompiler|CompilationContext)\.hx|src/reflaxe/c/(ast|emit|frontend|ir|lowering|naming|plan|semantics)/|test/(evaluation_order|hxc_ir)/|docs/evaluation-order\.md|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running explicit Haxe evaluation-order and differential probes..."
  python3 "$ROOT_DIR/test/evaluation_order/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(src/reflaxe/c/(CCompiler|CReflaxeCompiler|CompilationContext)\.hx|src/reflaxe/c/(ast|emit|frontend|ir|lowering|naming|plan|semantics)/|test/static_initialization/|docs/(diagnostics|static-initialization|testing)\.md|docs/specs/(diagnostics|fixture-taxonomy)\.json|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running deterministic static-initialization and cycle probes..."
  python3 "$ROOT_DIR/test/static_initialization/run.py"
fi

if printf '%s\n' "$STAGED_FILES" | grep -Eq '^(src/reflaxe/c/(CCompiler|CReflaxeCompiler|CompilationContext)\.hx|src/reflaxe/c/(ast|emit|frontend|ir|lowering|naming|plan|semantics)/|test/(arithmetic_semantics|hxc_ir)/|docs/(adr/0008-primitive-representations-and-conversions|arithmetic-semantics|body-lowering|evaluation-order|primitive-semantics)\.md|haxe_libraries/reflaxe\.c\.hxml|package\.json)'; then
  echo "[pre-commit] Running primitive arithmetic boundary, sanitizer, and optimized-shape probes..."
  python3 "$ROOT_DIR/test/arithmetic_semantics/run.py"
