# Dedicated E0.T04 graph check. The runner supplies either Eval for a complete
# non-C type-check or the real C custom target for the fail-closed HXC1001 path.

-cp test/all_sources/
-lib reflaxe.c

--macro include("reflaxe.c", true)
# `std/c/_std` is also visible below the ordinary `std` root as the physical
# package `c._std`. It is a target override, not a second public C package.
--macro include("c", true, ["c._std*"])
--macro include("hxc", true)
--macro include("raylib", true)
--macro include("raygui", true)

-main AllSourcesProbe
