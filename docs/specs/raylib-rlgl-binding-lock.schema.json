{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reflaxe.c.dev/schemas/raylib-rlgl-binding-lock.schema.json",
  "title": "Clang-derived raylib 6.0 rlgl quad-batch binding lock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generator",
    "upstream",
    "extraction",
    "selection",
    "declarations",
    "declarationSha256",
    "generatedPaths"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "algorithm"],
      "properties": {
        "path": { "const": "scripts/raylib/rlgl_binding.py" },
        "algorithm": { "const": "hxc-raylib-clang-rlgl-v1" }
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "release", "commit", "header", "licenseExpression", "licenseUrl"],
      "properties": {
        "name": { "const": "raylib" },
        "release": { "const": "6.0" },
        "commit": { "$ref": "#/$defs/revision" },
        "header": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "const": "src/rlgl.h" },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "licenseExpression": { "const": "Zlib" },
        "licenseUrl": { "type": "string", "pattern": "^https://github\\.com/raysan5/raylib/blob/[0-9a-f]{40}/LICENSE$" }
      }
    },
    "extraction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "clang", "requestedTarget", "arguments"],
      "properties": {
        "authority": { "const": "clang-ast-and-preprocessor" },
        "clang": {
          "type": "object",
          "additionalProperties": false,
          "required": ["family", "version", "dumpMachine"],
          "properties": {
            "family": { "const": "clang" },
            "version": { "type": "string", "minLength": 1 },
            "dumpMachine": { "type": "string", "minLength": 1 }
          }
        },
        "requestedTarget": { "const": "x86_64-unknown-linux-gnu" },
        "arguments": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "coverageState", "counts", "omissions"],
      "properties": {
        "path": { "const": "docs/specs/raylib-rlgl-selection.json" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "coverageState": { "const": "caxecraft-quad-batch-only" },
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["constants", "functions", "omittedFamilies"],
          "properties": {
            "constants": { "const": 1 },
            "functions": { "const": 7 },
            "omittedFamilies": { "const": 1 }
          }
        },
        "omissions": { "type": "array", "minItems": 1, "items": { "$ref": "raylib-rlgl-selection.schema.json#/$defs/omission" } }
      }
    },
    "declarations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["constant", "functions"],
      "properties": {
        "constant": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "value"],
          "properties": { "name": { "const": "RL_QUADS" }, "value": { "const": 7 } }
        },
        "functions": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": { "$ref": "#/$defs/function" }
        }
      }
    },
    "declarationSha256": { "$ref": "#/$defs/sha256" },
    "generatedPaths": {
      "const": ["src/raylib/raw/Rlgl.hx", "test/raylib_provisioning/native/rlgl_abi_probe.c"]
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "typeFact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cType", "canonicalCType", "haxeType"],
      "properties": {
        "cType": { "type": "string", "minLength": 1 },
        "canonicalCType": { "type": "string", "minLength": 1 },
        "haxeType": { "type": "string", "minLength": 1 }
      }
    },
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
        "type": { "$ref": "#/$defs/typeFact" }
      }
    },
    "function": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "parameters", "returnType", "sourceLine"],
      "properties": {
        "name": { "type": "string", "pattern": "^rl[A-Za-z0-9_]+$" },
        "parameters": { "type": "array", "items": { "$ref": "#/$defs/parameter" } },
        "returnType": { "$ref": "#/$defs/typeFact" },
        "sourceLine": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
