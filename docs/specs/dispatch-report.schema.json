{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reflaxe-c.dev/schemas/dispatch-report.schema.json",
  "title": "reflaxe.c reachable virtual-dispatch report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "algorithm",
    "status",
    "tablePolicy",
    "adapterPolicy",
    "runtimeFeatures",
    "summary",
    "calls",
    "layouts",
    "slots",
    "tables"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "algorithm": { "const": "hxc-closed-world-virtual-dispatch-v1" },
    "status": { "const": "analyzed-reachable-instance-dispatch" },
    "tablePolicy": { "const": "one-root-layout-reachable-virtual-slots-only" },
    "adapterPolicy": { "const": "representation-identical-overrides-with-typed-self-thunks" },
    "runtimeFeatures": {
      "type": "array",
      "maxItems": 0
    },
    "summary": { "$ref": "#/$defs/summary" },
    "calls": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/call" }
    },
    "layouts": {
      "type": "array",
      "items": { "$ref": "#/$defs/layout" }
    },
    "slots": {
      "type": "array",
      "items": { "$ref": "#/$defs/slot" }
    },
    "tables": {
      "type": "array",
      "items": { "$ref": "#/$defs/table" }
    }
  },
  "$defs": {
    "nonEmptyText": {
      "type": "string",
      "minLength": 1
    },
    "nullableText": {
      "oneOf": [
        { "$ref": "#/$defs/nonEmptyText" },
        { "type": "null" }
      ]
    },
    "cIdentifier": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "nullableIdentifier": {
      "oneOf": [
        { "$ref": "#/$defs/cIdentifier" },
        { "type": "null" }
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "startLine", "startColumn", "endLine", "endColumn"],
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.?/).+$"
        },
        "startLine": { "type": "integer", "minimum": 1 },
        "startColumn": { "type": "integer", "minimum": 1 },
        "endLine": { "type": "integer", "minimum": 1 },
        "endColumn": { "type": "integer", "minimum": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instanceCalls",
        "directCalls",
        "indirectCalls",
        "layouts",
        "slots",
        "tables",
        "adapters"
      ],
      "properties": {
        "instanceCalls": { "type": "integer", "minimum": 1 },
        "directCalls": { "type": "integer", "minimum": 0 },
        "indirectCalls": { "type": "integer", "minimum": 0 },
        "layouts": { "type": "integer", "minimum": 0 },
        "slots": { "type": "integer", "minimum": 0 },
        "tables": { "type": "integer", "minimum": 0 },
        "adapters": { "type": "integer", "minimum": 0 }
      }
    },
    "call": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "callerFunctionId",
        "methodFunctionId",
        "receiverStaticClass",
        "dispatch",
        "reason",
        "targetFunctionId",
        "slotId",
        "source"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^dispatch\\.call\\.[0-9]+$" },
        "callerFunctionId": { "$ref": "#/$defs/nonEmptyText" },
        "methodFunctionId": { "$ref": "#/$defs/nonEmptyText" },
        "receiverStaticClass": { "$ref": "#/$defs/nonEmptyText" },
        "dispatch": { "enum": ["direct", "virtual"] },
        "reason": { "$ref": "#/$defs/nonEmptyText" },
        "targetFunctionId": { "$ref": "#/$defs/nullableText" },
        "slotId": { "$ref": "#/$defs/nullableText" },
        "source": { "$ref": "#/$defs/source" }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rootInstanceId", "cTag", "slotIds"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyText" },
        "rootInstanceId": { "$ref": "#/$defs/nonEmptyText" },
        "cTag": { "$ref": "#/$defs/cIdentifier" },
        "slotIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/nonEmptyText" }
        }
      }
    },
    "slot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "ownerInstanceId",
        "cMember",
        "parameterRepresentations",
        "returnRepresentation"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyText" },
        "ownerInstanceId": { "$ref": "#/$defs/nonEmptyText" },
        "cMember": { "$ref": "#/$defs/cIdentifier" },
        "parameterRepresentations": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyText" }
        },
        "returnRepresentation": { "$ref": "#/$defs/nonEmptyText" }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slotId", "implementationFunctionId", "adapterCName"],
      "properties": {
        "slotId": { "$ref": "#/$defs/nonEmptyText" },
        "implementationFunctionId": { "$ref": "#/$defs/nullableText" },
        "adapterCName": { "$ref": "#/$defs/nullableIdentifier" }
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "layoutId", "classInstanceId", "cName", "entries"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyText" },
        "layoutId": { "$ref": "#/$defs/nonEmptyText" },
        "classInstanceId": { "$ref": "#/$defs/nonEmptyText" },
        "cName": { "$ref": "#/$defs/cIdentifier" },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/entry" }
        }
      }
    }
  }
}
