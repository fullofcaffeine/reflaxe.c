  "entries": [
    {
      "id": "div-int-modulo-zero",
      "status": "intentional-target-refinement",
      "ownerBeads": "E2.T11",
      "operation": "Int.%",
      "input": "7 % 0",
      "oracleExpectation": {
        "kind": "exact",
        "value": "nan"
      },
      "targetValue": "0",
      "contract": "docs/adr/0008-primitive-representations-and-conversions.md",
      "rationale": "The pinned Eval carrier exposes its own exceptional result, while hxc defines zero so generated C never executes undefined integer remainder.",
      "tests": [
        "test/primitive_differential/run.py"
      ]
    },
    {
      "id": "div-std-int-positive-infinity",
      "status": "intentional-target-refinement",
      "ownerBeads": "E2.T11",
      "operation": "Std.int(Float)",
      "input": "Math.POSITIVE_INFINITY",
      "oracleExpectation": {
        "kind": "host-dependent-int32",
        "canonicalValue": "<host-dependent-int32>"
      },
      "targetValue": "2147483647",
      "contract": "docs/adr/0008-primitive-representations-and-conversions.md",
      "rationale": "The C target saturates positive infinity before conversion instead of inheriting Eval's host-dependent OCaml out-of-range conversion result.",
      "tests": [
        "test/primitive_differential/run.py"
      ]
    },
    {
      "id": "div-std-int-positive-overflow",
      "status": "intentional-target-refinement",
      "ownerBeads": "E2.T11",
      "operation": "Std.int(Float)",
      "input": "2147483648.0",
      "oracleExpectation": {
        "kind": "exact",
        "value": "-2147483648"
      },
      "targetValue": "2147483647",
      "contract": "docs/adr/0008-primitive-representations-and-conversions.md",
      "rationale": "The C target saturates a finite positive overflow before conversion instead of inheriting Eval's exact wrapping result or undefined C behavior.",
      "tests": [
        "test/primitive_differential/run.py"
      ]
    }
  ]
}
