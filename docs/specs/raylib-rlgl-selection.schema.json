{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reflaxe.c.dev/schemas/raylib-rlgl-selection.schema.json",
  "title": "Curated raylib 6.0 rlgl quad-batch selection",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "constant", "functions", "omissions"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "constant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value"],
      "properties": {
        "name": { "const": "RL_QUADS" },
        "value": { "const": 7 }
      }
    },
    "functions": {
      "const": [
        "rlBegin",
        "rlColor4ub",
        "rlDrawRenderBatchActive",
        "rlEnd",
        "rlNormal3f",
        "rlSetTexture",
        "rlTexCoord2f",
        "rlVertex3f"
      ]
    },
    "omissions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/omission" }
    }
  },
  "$defs": {
    "omission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "reason", "owner"],
      "properties": {
        "family": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "reason": { "type": "string", "minLength": 40 },
        "owner": { "type": "string", "pattern": "^haxe_c-[a-z0-9]+(?:\\.[0-9]+)*$" }
      }
    }
  }
}
