{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reflaxe.c.dev/schemas/raylib-core-binding-lock.schema.json",
  "title": "Clang-derived raylib 6.0 Caxecraft core binding lock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generator",
    "upstream",
    "extraction",
    "selection",
    "canonicalAbi",
    "declarations",
    "declarationSha256",
    "generatedPaths"
  ],
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "algorithm"
      ],
      "properties": {
        "path": {
          "const": "scripts/raylib/core_binding.py"
        },
        "algorithm": {
          "const": "hxc-raylib-clang-core-v2"
        }
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "release",
        "apiVersion",
        "commit",
        "header",
        "licenseExpression",
        "licenseUrl"
      ],
      "properties": {
        "name": {
          "const": "raylib"
        },
        "release": {
          "const": "6.0"
        },
        "apiVersion": {
          "const": 600
        },
        "commit": {
          "$ref": "#/$defs/revision"
        },
        "header": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "sha256"
          ],
          "properties": {
            "path": {
              "const": "src/raylib.h"
            },
            "sha256": {
              "$ref": "#/$defs/sha256"
            }
          }
        },
        "licenseExpression": {
          "const": "Zlib"
        },
        "licenseUrl": {
          "type": "string",
          "pattern": "^https://github\\.com/raysan5/raylib/blob/[0-9a-f]{40}/LICENSE$"
        }
      }
    },
    "extraction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority",
        "clang",
        "requestedTarget",
        "arguments"
      ],
      "properties": {
        "authority": {
          "const": "clang-ast-json"
        },
        "clang": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "family",
            "version",
            "dumpMachine"
          ],
          "properties": {
            "family": {
              "const": "clang"
            },
            "version": {
              "type": "string",
              "minLength": 1
            },
            "dumpMachine": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "requestedTarget": {
          "const": "x86_64-unknown-linux-gnu"
        },
        "arguments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "coverageState",
        "counts",
        "omissions",
        "resourceContracts"
      ],
      "properties": {
        "path": {
          "const": "docs/specs/raylib-core-selection.json"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "coverageState": {
          "const": "coherent-caxecraft-core"
        },
        "counts": {
          "$ref": "#/$defs/counts"
        },
        "omissions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/omission"
          }
        },
        "resourceContracts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/resourceContract"
          }
        }
      }
    },
    "canonicalAbi": {
      "$ref": "#/$defs/canonicalAbi"
    },
    "declarations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "records",
        "aliases",
        "enums",
        "functions"
      ],
      "properties": {
        "records": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/record"
          }
        },
        "aliases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/alias"
          }
        },
        "enums": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/enum"
          }
        },
        "functions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/function"
          }
        }
      }
    },
    "declarationSha256": {
      "$ref": "#/$defs/sha256"
    },
    "generatedPaths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^src/raylib/raw/[A-Za-z_][A-Za-z0-9_]*\\.hx$"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "revision": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "name": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "line": {
      "type": "integer",
      "minimum": 1
    },
    "typeFact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cType",
        "canonicalCType",
        "haxeType"
      ],
      "properties": {
        "cType": {
          "type": "string",
          "minLength": 1
        },
        "canonicalCType": {
          "type": "string",
          "minLength": 1
        },
        "haxeType": {
          "type": "string",
          "pattern": "^(?:Void|Bool|Float|c\\.[A-Za-z0-9_]+|raylib\\.raw\\.[A-Za-z0-9_]+)$"
        }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "size",
        "alignment",
        "offsets"
      ],
      "properties": {
        "size": {
          "type": "integer",
          "minimum": 1
        },
        "alignment": {
          "type": "integer",
          "minimum": 1
        },
        "offsets": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "$ref": "#/$defs/name"
          },
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "canonicalAbi": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "languageStandard",
        "defines",
        "records"
      ],
      "properties": {
        "target": {
          "const": "x86_64-unknown-linux-gnu"
        },
        "languageStandard": {
          "const": "c11"
        },
        "defines": {
          "type": "array",
          "const": [
            "RAYLIB_NO_DEPRECATED"
          ]
        },
        "records": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "$ref": "#/$defs/name"
          },
          "additionalProperties": {
            "$ref": "#/$defs/layout"
          }
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "sourceLine",
        "type"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name"
        },
        "sourceLine": {
          "$ref": "#/$defs/line"
        },
        "type": {
          "$ref": "#/$defs/typeFact"
        }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "sourceLine",
        "fields",
        "canonicalAbi"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name"
        },
        "sourceLine": {
          "$ref": "#/$defs/line"
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/field"
          }
        },
        "canonicalAbi": {
          "$ref": "#/$defs/layout"
        }
      }
    },
    "alias": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "sourceLine",
        "target"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name"
        },
        "sourceLine": {
          "$ref": "#/$defs/line"
        },
        "target": {
          "$ref": "#/$defs/name"
        }
      }
    },
    "constant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "sourceLine",
        "value"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name"
        },
        "sourceLine": {
          "$ref": "#/$defs/line"
        },
        "value": {
          "type": "integer"
        }
      }
    },
    "enum": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "sourceLine",
        "underlyingCanonicalCType",
        "constants"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name"
        },
        "sourceLine": {
          "$ref": "#/$defs/line"
        },
        "underlyingCanonicalCType": {
          "const": "int"
        },
        "constants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/constant"
          }
        }
      }
    },
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name"
        },
        "type": {
          "$ref": "#/$defs/typeFact"
        }
      }
    },
    "function": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "sourceLine",
        "returnType",
        "parameters"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name"
        },
        "sourceLine": {
          "$ref": "#/$defs/line"
        },
        "returnType": {
          "$ref": "#/$defs/typeFact"
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/parameter"
          }
        }
      }
    },
    "omission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "reason",
        "owner"
      ],
      "properties": {
        "family": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "reason": {
          "type": "string",
          "minLength": 20
        },
        "owner": {
          "type": "string",
          "pattern": "^haxe_c-[a-z0-9]+(?:\\.[0-9]+)?$"
        }
      }
    },
    "resourceContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resource",
        "load",
        "validate",
        "borrow",
        "unload",
        "ownership",
        "thread",
        "failure",
        "semanticStatus"
      ],
      "properties": {
        "resource": { "$ref": "#/$defs/name" },
        "load": { "$ref": "#/$defs/name" },
        "validate": { "$ref": "#/$defs/name" },
        "borrow": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/name" },
          "uniqueItems": true
        },
        "unload": { "$ref": "#/$defs/name" },
        "ownership": { "type": "string", "minLength": 20 },
        "thread": { "type": "string", "minLength": 20 },
        "failure": { "type": "string", "minLength": 20 },
        "semanticStatus": { "const": "raw-only-until-explicit-cleanup-edges" }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "records",
        "aliases",
        "enums",
        "enumConstants",
        "functions",
        "omittedFamilies"
      ],
      "properties": {
        "records": {
          "type": "integer",
          "minimum": 1
        },
        "aliases": {
          "type": "integer",
          "minimum": 1
        },
        "enums": {
          "type": "integer",
          "minimum": 1
        },
        "enumConstants": {
          "type": "integer",
          "minimum": 1
        },
        "functions": {
          "type": "integer",
          "minimum": 1
        },
        "omittedFamilies": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
