{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reflaxe.c.dev/schemas/raylib-provisioning-lock.schema.json",
  "title": "Pinned raylib provisioning authority",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "upstream",
    "reviewedInputs",
    "configurations",
    "platforms",
    "authorities",
    "report"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "release",
        "packageVersion",
        "apiVersion",
        "commit",
        "archive",
        "sourceTree",
        "licenseExpression",
        "licenseUrl"
      ],
      "properties": {
        "name": {
          "const": "raylib"
        },
        "release": {
          "const": "6.0"
        },
        "packageVersion": {
          "const": "6.0.0"
        },
        "apiVersion": {
          "const": 600
        },
        "commit": {
          "$ref": "#/$defs/revision"
        },
        "archive": {
          "$ref": "#/$defs/archive"
        },
        "sourceTree": {
          "$ref": "#/$defs/sourceTree"
        },
        "licenseExpression": {
          "const": "Zlib"
        },
        "licenseUrl": {
          "type": "string",
          "pattern": "^https://github\\.com/raysan5/raylib/blob/[0-9a-f]{40}/LICENSE$"
        }
      }
    },
    "reviewedInputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/input"
      }
    },
    "configurations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memory-software",
        "desktop"
      ],
      "properties": {
        "memory-software": {
          "$ref": "#/$defs/configuration"
        },
        "desktop": {
          "$ref": "#/$defs/configuration"
        }
      }
    },
    "platforms": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "linux",
        "macos",
        "windows"
      ],
      "properties": {
        "linux": {
          "$ref": "#/$defs/platform"
        },
        "macos": {
          "$ref": "#/$defs/platform"
        },
        "windows": {
          "$ref": "#/$defs/platform"
        }
      }
    },
    "authorities": {
      "type": "array",
      "const": [
        "pinned-source",
        "offline-source",
        "system-pkg-config"
      ]
    },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "pathPlaceholders",
        "forbiddenHostFacts"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "pathPlaceholders": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^\\$\\{[A-Z_]+\\}$"
          },
          "uniqueItems": true
        },
        "forbiddenHostFacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "revision": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "archive": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "sha256",
        "sizeBytes",
        "rootDirectory"
      ],
      "properties": {
        "url": {
          "type": "string",
          "pattern": "^https://codeload\\.github\\.com/raysan5/raylib/tar\\.gz/[0-9a-f]{40}$"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 1
        },
        "rootDirectory": {
          "type": "string",
          "pattern": "^raylib-[0-9a-f]{40}$"
        }
      }
    },
    "sourceTree": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "sha256",
        "fileCount",
        "sizeBytes"
      ],
      "properties": {
        "algorithm": {
          "const": "hxc-path-size-content-sha256-v1"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "fileCount": {
          "type": "integer",
          "minimum": 1
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "graphicsApi",
        "runEvidence",
        "cmakeDefinitions"
      ],
      "properties": {
        "platform": {
          "enum": [
            "Memory",
            "Desktop"
          ]
        },
        "graphicsApi": {
          "enum": [
            "Software",
            "3.3"
          ]
        },
        "runEvidence": {
          "type": "boolean"
        },
        "cmakeDefinitions": {
          "$ref": "#/$defs/definitions"
        }
      }
    },
    "definitions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]*=[A-Za-z0-9.+_-]+$"
      },
      "uniqueItems": true
    },
    "linkFacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "libraries",
        "frameworks"
      ],
      "properties": {
        "libraries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_][A-Za-z0-9_+.-]*$"
          },
          "uniqueItems": true
        },
        "frameworks": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_][A-Za-z0-9_+.-]*$"
          },
          "uniqueItems": true
        },
        "cmakeDefinitions": {
          "$ref": "#/$defs/definitions"
        }
      }
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memory-software",
        "desktop"
      ],
      "properties": {
        "memory-software": {
          "$ref": "#/$defs/linkFacts"
        },
        "desktop": {
          "$ref": "#/$defs/linkFacts"
        }
      }
    }
  }
}
