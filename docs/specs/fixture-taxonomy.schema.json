{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reflaxe.c.dev/schemas/fixture-taxonomy.schema.json",
  "title": "reflaxe.c fixture taxonomy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "caseSchema",
    "runnerContract",
    "types",
    "suites",
    "snapshotPolicy",
    "examplesPolicy"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "caseSchema": {
      "$ref": "#/$defs/path"
    },
    "runnerContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "caseManifest",
        "defaultWorkingDirectory",
        "defaultTimeoutSeconds",
        "networkDefault",
        "requiredExpectedFields"
      ],
      "properties": {
        "caseManifest": {
          "const": "case.json"
        },
        "defaultWorkingDirectory": {
          "const": "case-directory"
        },
        "defaultTimeoutSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "networkDefault": {
          "const": false
        },
        "requiredExpectedFields": {
          "type": "array",
          "contains": {
            "const": "exitCode"
          },
          "uniqueItems": true
        }
      }
    },
    "types": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "directory",
          "status",
          "purpose",
          "expectedOutputs",
          "suiteIds"
        ],
        "properties": {
          "id": {
            "enum": [
              "positive",
              "negative",
              "ast",
              "snapshot",
              "runtime",
              "differential",
              "abi",
              "performance"
            ]
          },
          "directory": {
            "$ref": "#/$defs/path"
          },
          "status": {
            "enum": [
              "active",
              "seed-only",
              "contract-only"
            ]
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "expectedOutputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "suiteIds": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        }
      }
    },
    "suites": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "directory",
          "runner",
          "types",
          "status",
          "assertions"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "directory": {
            "$ref": "#/$defs/path"
          },
          "runner": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "snapshotValidationRunner": {
            "description": "Optional focused command used only after the registered updater has already rendered the suite twice; the ordinary runner remains the exhaustive suite authority.",
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "types": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "status": {
            "enum": [
              "active",
              "seed-only"
            ]
          },
          "assertions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "snapshotPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkCommand",
        "integratedCheckCommand",
        "updateCommand",
        "ciMayUpdate",
        "diffFormat",
        "managedSuites"
      ],
      "properties": {
        "checkCommand": {
          "type": "string"
        },
        "integratedCheckCommand": {
          "const": "npm run snapshots:catalog"
        },
        "updateCommand": {
          "type": "string"
        },
        "ciMayUpdate": {
          "const": false
        },
        "diffFormat": {
          "const": "unified-semantic"
        },
        "managedSuites": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "expectedRoots",
              "formats"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "expectedRoots": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "#/$defs/path"
                },
                "uniqueItems": true
              },
              "formats": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "enum": [
                    "text",
                    "json",
                    "c",
                    "header",
                    "hxcir"
                  ]
                },
                "uniqueItems": true
              }
            }
          }
        }
      }
    },
    "examplesPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "directory",
        "status",
        "caseManifest",
        "requiredExpectedAssertions"
      ],
      "properties": {
        "directory": {
          "const": "examples"
        },
        "status": {
          "enum": [
            "absent",
            "active"
          ]
        },
        "caseManifest": {
          "const": "case.json"
        },
        "requiredExpectedAssertions": {
          "type": "array",
          "minItems": 2,
          "contains": {
            "const": "exitCode"
          },
          "uniqueItems": true
        }
      }
    }
  },
  "$defs": {
    "path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    }
  }
}
