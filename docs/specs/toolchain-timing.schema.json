{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reflaxe.c.dev/schemas/toolchain-timing.schema.json",
  "title": "reflaxe.c toolchain timing evidence",
  "oneOf": [
    {
      "$ref": "#/$defs/shardReport"
    },
    {
      "$ref": "#/$defs/parallelReport"
    }
  ],
  "$defs": {
    "outcome": {
      "enum": [
        "passed",
        "failed"
      ]
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script",
        "outcome",
        "exitCode",
        "durationMs"
      ],
      "properties": {
        "script": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "$ref": "#/$defs/outcome"
        },
        "exitCode": {
          "type": [
            "integer",
            "null"
          ]
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        },
        "phaseTiming": {
          "$ref": "#/$defs/caxecraftTiming"
        }
      }
    },
    "caxecraftTiming": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "suite",
        "mode",
        "outcome",
        "durationMs",
        "summary",
        "phases"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "suite": {
          "const": "caxecraft-domain"
        },
        "mode": {
          "const": "full"
        },
        "outcome": {
          "$ref": "#/$defs/outcome"
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "haxeRequests"
          ],
          "properties": {
            "haxeRequests": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "phases": {
          "type": "array",
          "minItems": 0,
          "maxItems": 7,
          "prefixItems": [
            {
              "$ref": "#/$defs/caxecraftAssetPhase"
            },
            {
              "$ref": "#/$defs/caxecraftEvalPhase"
            },
            {
              "$ref": "#/$defs/caxecraftBackendPhase"
            },
            {
              "$ref": "#/$defs/caxecraftColdPhase"
            },
            {
              "$ref": "#/$defs/caxecraftWarmPhase"
            },
            {
              "$ref": "#/$defs/caxecraftSnapshotPhase"
            },
            {
              "$ref": "#/$defs/caxecraftNativePhase"
            }
          ],
          "items": false
        }
      }
    },
    "caxecraftAssetPhase": {
      "$ref": "#/$defs/caxecraftPhase",
      "properties": {
        "name": {
          "const": "asset-contracts"
        },
        "haxeRequests": {
          "const": 0
        }
      }
    },
    "caxecraftEvalPhase": {
      "$ref": "#/$defs/caxecraftPhase",
      "properties": {
        "name": {
          "const": "eval-oracle"
        },
        "haxeRequests": {
          "const": 1
        }
      }
    },
    "caxecraftBackendPhase": {
      "$ref": "#/$defs/caxecraftPhase",
      "properties": {
        "name": {
          "const": "backend-render"
        },
        "haxeRequests": {
          "const": 3
        }
      }
    },
    "caxecraftColdPhase": {
      "$ref": "#/$defs/caxecraftPhase",
      "properties": {
        "name": {
          "const": "cold-determinism"
        },
        "haxeRequests": {
          "const": 4
        }
      }
    },
    "caxecraftWarmPhase": {
      "$ref": "#/$defs/caxecraftPhase",
      "properties": {
        "name": {
          "const": "warm-server"
        },
        "haxeRequests": {
          "const": 4
        }
      }
    },
    "caxecraftSnapshotPhase": {
      "$ref": "#/$defs/caxecraftPhase",
      "properties": {
        "name": {
          "const": "snapshot-validation"
        },
        "haxeRequests": {
          "const": 0
        }
      }
    },
    "caxecraftNativePhase": {
      "$ref": "#/$defs/caxecraftPhase",
      "properties": {
        "name": {
          "const": "native-build-run"
        },
        "haxeRequests": {
          "const": 0
        }
      }
    },
    "caxecraftPhase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "outcome",
        "durationMs",
        "haxeRequests"
      ],
      "properties": {
        "name": {
          "enum": [
            "asset-contracts",
            "eval-oracle",
            "backend-render",
            "cold-determinism",
            "warm-server",
            "snapshot-validation",
            "native-build-run"
          ]
        },
        "outcome": {
          "$ref": "#/$defs/outcome"
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        },
        "haxeRequests": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "shardReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "shard",
        "outcome",
        "durationMs",
        "commands"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "shard": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "$ref": "#/$defs/outcome"
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/command"
          }
        }
      }
    },
    "parallelReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "outcome",
        "durationMs",
        "jobs",
        "workerSelection",
        "executedShards",
        "reusedShards"
      ],
      "properties": {
        "schemaVersion": {
          "const": 2
        },
        "outcome": {
          "$ref": "#/$defs/outcome"
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        },
        "jobs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "workerSelection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "logicalCpuCount",
            "oneMinuteLoad",
            "reason"
          ],
          "properties": {
            "source": {
              "type": "string",
              "minLength": 1
            },
            "logicalCpuCount": {
              "type": "integer",
              "minimum": 1
            },
            "oneMinuteLoad": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "executedShards": {
          "type": "array",
          "minItems": 0,
          "items": {
            "$ref": "#/$defs/shardReport"
          }
        },
        "reusedShards": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "shard",
              "evidenceAgeSeconds",
              "evidenceKey"
            ],
            "properties": {
              "shard": {
                "type": "string",
                "minLength": 1
              },
              "evidenceAgeSeconds": {
                "type": "integer",
                "minimum": 0
              },
              "evidenceKey": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              }
            }
          }
        }
      }
    }
  }
}
