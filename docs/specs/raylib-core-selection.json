  "omissions": [
    {
      "family": "callbacks",
      "reason": "Callback calling convention, retention, thread, and exception boundaries are not yet represented by the reusable C interop layer.",
      "owner": "haxe_c-xge.10"
    },
    {
      "family": "variadics",
      "reason": "C variadics such as TraceLog and TextFormat require a separate typed policy and are never approximated as fixed-arity calls.",
      "owner": "haxe_c-xge.10"
    },
    {
      "family": "borrowed-or-retained-pointers",
      "reason": "Pointer depth, nullability, lifetime, and mutation authority need explicit machine-readable ownership before admission.",
      "owner": "haxe_c-xge.10"
    },
    {
      "family": "remaining-resource-owning-apis",
      "reason": "The selected raw Texture2D load/draw/unload family now has an explicit owner contract; images, fonts, models, shaders, audio, file buffers, and semantic owned-resource helpers still need their own paired lifetime and cleanup proof.",
      "owner": "haxe_c-xge.10"
    },
    {
      "family": "compound-literal-color-macros",
      "reason": "Raylib color macros expand to C compound literals; typed allocation-free Haxe constants belong in the reviewed semantic facade.",
      "owner": "haxe_c-xge.4"
    },
    {
      "family": "remaining-public-header",
      "reason": "This release is the complete coherent Caxecraft core, not a claim of complete raylib 6.0 binding coverage.",
