{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reflaxe.c.dev/schemas/raylib-core-selection.schema.json",
  "title": "Curated raylib 6.0 Caxecraft core selection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "records",
    "aliases",
    "enums",
    "functions",
    "resourceContracts",
    "canonicalAbi",
    "omissions"
  ],
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "records": {
      "$ref": "#/$defs/names"
    },
    "aliases": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/name"
      },
      "additionalProperties": {
        "$ref": "#/$defs/name"
      }
    },
    "enums": {
      "$ref": "#/$defs/names"
    },
    "functions": {
      "$ref": "#/$defs/names"
    },
    "resourceContracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/resourceContract"
      }
    },
    "canonicalAbi": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "languageStandard",
        "defines",
        "records"
      ],
      "properties": {
        "target": {
          "const": "x86_64-unknown-linux-gnu"
        },
        "languageStandard": {
          "const": "c11"
        },
        "defines": {
          "type": "array",
          "const": [
            "RAYLIB_NO_DEPRECATED"
          ]
        },
        "records": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "$ref": "#/$defs/name"
          },
          "additionalProperties": {
            "$ref": "#/$defs/layout"
          }
        }
      }
    },
    "omissions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "family",
          "reason",
          "owner"
        ],
        "properties": {
          "family": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "reason": {
            "type": "string",
            "minLength": 20
          },
          "owner": {
            "type": "string",
            "pattern": "^haxe_c-[a-z0-9]+(?:\\.[0-9]+)?$"
          }
        }
      }
    }
  },
  "$defs": {
    "name": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "names": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/name"
      },
      "uniqueItems": true
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "size",
        "alignment",
        "offsets"
      ],
      "properties": {
        "size": {
          "type": "integer",
          "minimum": 1
        },
        "alignment": {
          "type": "integer",
          "minimum": 1
        },
        "offsets": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "$ref": "#/$defs/name"
          },
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "resourceContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resource",
        "load",
        "validate",
        "borrow",
        "unload",
        "ownership",
        "thread",
        "failure",
        "semanticStatus"
      ],
      "properties": {
        "resource": { "$ref": "#/$defs/name" },
        "load": { "$ref": "#/$defs/name" },
        "validate": { "$ref": "#/$defs/name" },
        "borrow": { "$ref": "#/$defs/names" },
        "unload": { "$ref": "#/$defs/name" },
        "ownership": { "type": "string", "minLength": 20 },
        "thread": { "type": "string", "minLength": 20 },
        "failure": { "type": "string", "minLength": 20 },
        "semanticStatus": { "const": "raw-only-until-explicit-cleanup-edges" }
      }
    }
  }
}
