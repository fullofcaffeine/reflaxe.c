{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reflaxe.c.dev/schemas/runtime-features.schema.json",
  "title": "reflaxe.c runtime feature registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "algorithm",
    "status",
    "requirements",
    "noUnconditionalCore",
    "runtimeAbi",
    "compilerSelectableFeatures",
    "features",
    "reservedFeatures"
  ],
  "properties": {
    "schemaVersion": {
      "const": 3
    },
    "algorithm": {
      "const": "hxc-runtime-feature-graph-v3"
    },
    "status": {
      "enum": [
        "provisional-native-seed-packaging",
        "selective-compiler-packaging"
      ]
    },
    "requirements": {
      "type": "array",
      "items": {
        "enum": [
          "HXC-RT-001",
          "HXC-RT-002",
          "HXC-RT-004",
          "HXC-RT-008",
          "HXC-RT-010",
          "HXC-RT-012"
        ]
      },
      "minItems": 6,
      "maxItems": 6,
      "uniqueItems": true
    },
    "noUnconditionalCore": {
      "const": true
    },
    "runtimeAbi": {
      "$ref": "#/$defs/runtimeAbi"
    },
    "compilerSelectableFeatures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/featureId"
      },
      "uniqueItems": true
    },
    "features": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/feature"
      },
      "uniqueItems": true
    },
    "reservedFeatures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reservation"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "featureId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "summary",
        "availability",
        "minimalAllowed",
        "environments",
        "dependencies",
        "artifacts",
        "symbols",
        "libraries",
        "defines",
        "documentation"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/featureId"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "availability": {
          "enum": [
            "compiler-selectable",
            "native-seed-only"
          ]
        },
        "minimalAllowed": {
          "type": "boolean"
        },
        "environments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "hosted",
              "freestanding",
              "wasi",
              "emscripten"
            ]
          },
          "uniqueItems": true
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/featureId"
          },
          "uniqueItems": true
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          },
          "uniqueItems": true
        },
        "symbols": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^hxc_[A-Za-z0-9_]+$"
          },
          "uniqueItems": true
        },
        "libraries": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "defines": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*=.+$"
          },
          "uniqueItems": true
        },
        "documentation": {
          "$ref": "#/$defs/featureDocumentation"
        }
      }
    },
    "featureDocumentation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract",
        "selectionRoots",
        "directAlternative",
        "programLocalAlternative",
        "runtimeRationale",
        "referencePath",
        "evidence"
      ],
      "properties": {
        "contract": {
          "$ref": "#/$defs/singleLineText"
        },
        "selectionRoots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/selectionRoot"
          }
        },
        "directAlternative": {
          "$ref": "#/$defs/singleLineText"
        },
        "programLocalAlternative": {
          "$ref": "#/$defs/singleLineText"
        },
        "runtimeRationale": {
          "$ref": "#/$defs/singleLineText"
        },
        "referencePath": {
          "allOf": [
            { "$ref": "#/$defs/relativePath" },
            { "pattern": "^docs/.+\\.md$" }
          ]
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/relativePath"
          }
        }
      }
    },
    "selectionRoot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "description"],
      "properties": {
        "id": {
          "$ref": "#/$defs/featureId"
        },
        "kind": {
          "enum": [
            "hxc-ir-operation",
            "transitive-dependency",
            "native-seed-fixture"
          ]
        },
        "description": {
          "$ref": "#/$defs/singleLineText"
        }
      }
    },
    "singleLineText": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\r\\n\\u0000]+$"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourcePath",
        "outputPath",
        "kind",
        "sourceSha256"
      ],
      "properties": {
        "sourcePath": {
          "$ref": "#/$defs/relativePath"
        },
        "outputPath": {
          "$ref": "#/$defs/relativePath"
        },
        "kind": {
          "enum": [
            "runtime-header",
            "runtime-source"
          ]
        },
        "sourceSha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "runtimeAbi": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stability",
        "version",
        "generatedCodeCompatibility",
        "generatedCodeCheck",
        "runtimeMajorMacro",
        "publicBoundary",
        "releaseProvenance"
      ],
      "properties": {
        "stability": {
          "const": "internal-versioned"
        },
        "version": {
          "type": "object",
          "additionalProperties": false,
          "required": ["major", "minor", "patch"],
          "properties": {
            "major": { "type": "integer", "minimum": 0, "maximum": 255 },
            "minor": { "type": "integer", "minimum": 0, "maximum": 4095 },
            "patch": { "type": "integer", "minimum": 0, "maximum": 4095 }
          }
        },
        "generatedCodeCompatibility": {
          "const": "same-major"
        },
        "generatedCodeCheck": {
          "const": "c11-static-assert"
        },
        "runtimeMajorMacro": {
          "const": "HXC_RUNTIME_ABI_MAJOR"
        },
        "publicBoundary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["applicationAbiStatus", "exportTypePolicy", "forbiddenRuntimeTypes"],
          "properties": {
            "applicationAbiStatus": {
              "const": "unsupported"
            },
            "exportTypePolicy": {
              "const": "runtime-structs-forbidden"
            },
            "forbiddenRuntimeTypes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^hxc_[A-Za-z0-9_]+$"
              }
            }
          }
        },
        "releaseProvenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sourceHashAlgorithm", "sourceSetSha256", "runtimeCStandard", "publicHeaderCppStandard"],
          "properties": {
            "sourceHashAlgorithm": {
              "const": "sha256"
            },
            "sourceSetSha256": {
              "$ref": "#/$defs/sha256"
            },
            "runtimeCStandard": {
              "const": "c11"
            },
            "publicHeaderCppStandard": {
              "const": "c++17"
            }
          }
        }
      }
    },
    "reservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "ownerTask",
        "summary"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/featureId"
        },
        "ownerTask": {
          "type": "string",
          "pattern": "^E[0-9]+\\.T[0-9]+$"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
