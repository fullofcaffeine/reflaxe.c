{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reflaxe.c.dev/schemas/runtime-features.schema.json",
  "title": "reflaxe.c runtime feature registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "algorithm",
    "status",
    "requirements",
    "noUnconditionalCore",
    "compilerSelectableFeatures",
    "features",
    "reservedFeatures"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "algorithm": {
      "const": "hxc-runtime-feature-graph-v1"
    },
    "status": {
      "const": "provisional-native-seed-packaging"
    },
    "requirements": {
      "type": "array",
      "items": {
        "enum": [
          "HXC-RT-001",
          "HXC-RT-002",
          "HXC-RT-004",
          "HXC-RT-008"
        ]
      },
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true
    },
    "noUnconditionalCore": {
      "const": true
    },
    "compilerSelectableFeatures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/featureId"
      },
      "uniqueItems": true
    },
    "features": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/feature"
      },
      "uniqueItems": true
    },
    "reservedFeatures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reservation"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "featureId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "summary",
        "availability",
        "minimalAllowed",
        "environments",
        "dependencies",
        "artifacts",
        "symbols",
        "libraries",
        "defines"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/featureId"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "availability": {
          "enum": [
            "compiler-selectable",
            "native-seed-only"
          ]
        },
        "minimalAllowed": {
          "type": "boolean"
        },
        "environments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "hosted",
              "freestanding",
              "wasi",
              "emscripten"
            ]
          },
          "uniqueItems": true
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/featureId"
          },
          "uniqueItems": true
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          },
          "uniqueItems": true
        },
        "symbols": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^hxc_[A-Za-z0-9_]+$"
          },
          "uniqueItems": true
        },
        "libraries": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "defines": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*=.+$"
          },
          "uniqueItems": true
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourcePath",
        "outputPath",
        "kind"
      ],
      "properties": {
        "sourcePath": {
          "$ref": "#/$defs/relativePath"
        },
        "outputPath": {
          "$ref": "#/$defs/relativePath"
        },
        "kind": {
          "enum": [
            "runtime-header",
            "runtime-source"
          ]
        }
      }
    },
    "reservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "ownerTask",
        "summary"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/featureId"
        },
        "ownerTask": {
          "type": "string",
          "pattern": "^E[0-9]+\\.T[0-9]+$"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
