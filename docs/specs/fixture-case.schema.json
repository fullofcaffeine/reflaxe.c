{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reflaxe.c.dev/schemas/fixture-case.schema.json",
  "title": "reflaxe.c fixture or example case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "role",
    "type",
    "status",
    "sources",
    "runner",
    "expected"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "role": {
      "enum": [
        "fixture",
        "example"
      ]
    },
    "type": {
      "enum": [
        "positive",
        "negative",
        "ast",
        "snapshot",
        "runtime",
        "differential",
        "abi",
        "performance"
      ]
    },
    "status": {
      "enum": [
        "active",
        "planned",
        "disabled"
      ]
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^HXC-[A-Z]+-[0-9]{3}$"
      },
      "uniqueItems": true
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/relativePath"
      },
      "uniqueItems": true
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "workingDirectory",
        "timeoutSeconds",
        "network"
      ],
      "properties": {
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "workingDirectory": {
          "$ref": "#/$defs/relativePath"
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        },
        "network": {
          "type": "boolean"
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exitCode"
      ],
      "minProperties": 2,
      "properties": {
        "exitCode": {
          "type": "integer"
        },
        "stdout": {
          "$ref": "#/$defs/streamAssertion"
        },
        "stderr": {
          "$ref": "#/$defs/streamAssertion"
        },
        "diagnostics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^HXC[0-9]{4}$"
          },
          "uniqueItems": true
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "format",
              "comparison"
            ],
            "properties": {
              "path": {
                "$ref": "#/$defs/relativePath"
              },
              "format": {
                "enum": [
                  "text",
                  "json",
                  "c",
                  "header",
                  "hxcir",
                  "binary",
                  "metrics"
                ]
              },
              "comparison": {
                "enum": [
                  "exact",
                  "semantic-json",
                  "symbols",
                  "layout",
                  "budget"
                ]
              }
            }
          }
        },
        "runtimePlan": {
          "$ref": "#/$defs/relativePath"
        },
        "oracle": {
          "$ref": "#/$defs/relativePath"
        },
        "metrics": {
          "$ref": "#/$defs/relativePath"
        }
      },
      "anyOf": [
        {
          "required": [
            "stdout"
          ]
        },
        {
          "required": [
            "stderr"
          ]
        },
        {
          "required": [
            "diagnostics"
          ]
        },
        {
          "required": [
            "artifacts"
          ]
        },
        {
          "required": [
            "runtimePlan"
          ]
        },
        {
          "required": [
            "oracle"
          ]
        },
        {
          "required": [
            "metrics"
          ]
        }
      ]
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "streamAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "enum": [
            "empty",
            "exact",
            "regex",
            "json"
          ]
        },
        "value": {
          "type": "string"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        }
      },
      "oneOf": [
        {
          "properties": {
            "mode": {
              "const": "empty"
            }
          },
          "not": {
            "anyOf": [
              {
                "required": [
                  "value"
                ]
              },
              {
                "required": [
                  "path"
                ]
              }
            ]
          }
        },
        {
          "properties": {
            "mode": {
              "enum": [
                "exact",
                "regex",
                "json"
              ]
            }
          },
          "oneOf": [
            {
              "required": [
                "value"
              ]
            },
            {
              "required": [
                "path"
              ]
            }
          ]
        }
      ]
    }
  }
}
