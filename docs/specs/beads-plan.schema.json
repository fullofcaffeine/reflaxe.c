{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reflaxe-c.dev/schemas/beads-plan.schema.json",
  "title": "reflaxe.c reproducible Beads seed graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "planVersion", "project", "epics", "tasks"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "planVersion": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "project": { "$ref": "#/$defs/project" },
    "epics": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/epic" }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "nonemptyString": { "type": "string", "minLength": 1 },
    "priority": { "type": "integer", "minimum": 0, "maximum": 4 },
    "epicKey": { "type": "string", "pattern": "^E(0|[1-9][0-9]*)$" },
    "taskKey": {
      "type": "string",
      "pattern": "^E(0|[1-9][0-9]*)\\.T[0-9]{2}$"
    },
    "label": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*$"
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/nonemptyString" }
    },
    "labels": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/label" }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "issueTitlePrefix",
        "sourceOfIntent",
        "sourceOfExecution",
        "bootstrap",
        "rules"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/nonemptyString" },
        "issueTitlePrefix": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9]*$"
        },
        "sourceOfIntent": { "$ref": "#/$defs/nonemptyString" },
        "sourceOfExecution": { "$ref": "#/$defs/nonemptyString" },
        "bootstrap": { "$ref": "#/$defs/nonemptyString" },
        "rules": { "$ref": "#/$defs/stringList" }
      }
    },
    "epic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "title",
        "priority",
        "milestone",
        "description",
        "acceptance",
        "labels"
      ],
      "properties": {
        "key": { "$ref": "#/$defs/epicKey" },
        "title": { "$ref": "#/$defs/nonemptyString" },
        "priority": { "$ref": "#/$defs/priority" },
        "milestone": {
          "type": "string",
          "pattern": "^M(0|[1-9][0-9]*)$"
        },
        "description": { "$ref": "#/$defs/nonemptyString" },
        "acceptance": { "$ref": "#/$defs/stringList" },
        "labels": { "$ref": "#/$defs/labels" }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "epic",
        "title",
        "priority",
        "blockedBy",
        "prd",
        "requirements",
        "outcome",
        "acceptance",
        "labels",
        "effort",
        "type",
        "description"
      ],
      "properties": {
        "key": { "$ref": "#/$defs/taskKey" },
        "epic": { "$ref": "#/$defs/epicKey" },
        "title": { "$ref": "#/$defs/nonemptyString" },
        "priority": { "$ref": "#/$defs/priority" },
        "blockedBy": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/taskKey" }
        },
        "prd": { "$ref": "#/$defs/stringList" },
        "requirements": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^HXC-[A-Z]+-[0-9]{3}$"
          }
        },
        "outcome": { "$ref": "#/$defs/nonemptyString" },
        "acceptance": { "$ref": "#/$defs/stringList" },
        "labels": { "$ref": "#/$defs/labels" },
        "effort": { "enum": ["small", "medium", "large", "xlarge"] },
        "type": { "enum": ["task", "feature", "bug", "chore", "decision"] },
        "description": { "$ref": "#/$defs/nonemptyString" }
      }
    }
  }
}
